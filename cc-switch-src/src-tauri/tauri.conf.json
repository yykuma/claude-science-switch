{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Science Switch",
  "version": "3.16.5",
  "identifier": "com.claude-science-switch.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm run dev:renderer",
    "beforeBuildCommand": "pnpm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "titleBarStyle": "Overlay",
        "width": 1000,
        "height": 650,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https: http:",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../bin/native/claude-science-switch": "claude-science-switch/bin/claude-science-switch",
      "../../bin/claude-science-switch.js": "claude-science-switch/bin/claude-science-switch.js",
      "../../examples/cliproxy-gpt55.json": "claude-science-switch/examples/cliproxy-gpt55.json",
      "../../examples/cc-switch-provider-openai-chat.json": "claude-science-switch/examples/cc-switch-provider-openai-chat.json",
      "../../examples/multi-provider.json": "claude-science-switch/examples/multi-provider.json",
      "../../examples/science-provider-presets.json": "claude-science-switch/examples/science-provider-presets.json",
      "../../package.json": "claude-science-switch/package.json"
    },
    "windows": {
      "wix": {
        "template": "wix/per-user-main.wxs"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["claude-science-switch"]
      }
    }
  }
}
